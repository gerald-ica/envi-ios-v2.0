rules_version = '2';

// ENVI Firestore security rules — v1.1 connector foundation.
//
// Phase 06-03: base per-user read on `users/{uid}/connections/{provider}`.
// Phase 07:    admin-only collections for the OAuth broker:
//   - oauth_pending/{stateToken}                          — PKCE verifiers
//   - users/{uid}/connections/{provider}/rotationHistory — refresh hashes
//   - securityEvents/{eventId}                            — audit trail
//
// Design principles:
//   - Every write to `users/{uid}/connections/**` goes through the Admin SDK
//     running in Cloud Functions (the OAuth broker). Clients NEVER write
//     token material directly.
//   - Reads are scoped strictly to the authenticated user's own document.
//   - We fail closed: anything not explicitly allowed is denied.
//
// Tests live in `functions/src/__tests__/firestore.rules.test.ts` and run
// against the Firestore emulator via @firebase/rules-unit-testing.

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------
    // User profile root. Phase 2 already established per-user isolation
    // here; reiterated so the nested connections subcollection inherits a
    // reasonable default.
    // -------------------------------------------------------------------
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;  // Admin SDK only

      // ---------------------------------------------------------------
      // Social connector tokens. Per-provider document. Read-only for
      // the owning user; writes are Admin SDK only (rules evaluated on
      // client path; Admin SDK bypasses rules by design).
      // ---------------------------------------------------------------
      match /connections/{provider} {
        allow read: if request.auth != null
                      && request.auth.uid == uid
                      && provider in ["tiktok", "x", "instagram", "facebook", "threads", "linkedin"];
        allow write: if false;  // Admin SDK only

        // Rotation history — never exposed to the client. Admin SDK only.
        match /rotationHistory/{hash} {
          allow read, write: if false;
        }
      }
    }

    // -------------------------------------------------------------------
    // Phase 07: PKCE pending records. Opaque to clients — the broker is
    // the only reader/writer. TTL is declared via firestore.indexes.json.
    // -------------------------------------------------------------------
    match /oauth_pending/{stateToken} {
      allow read, write: if false;  // Admin SDK only
    }

    // -------------------------------------------------------------------
    // Phase 07: security audit events (refresh-token reuse, etc).
    // Not user-visible; admin/monitoring tooling reads via server SDK.
    // -------------------------------------------------------------------
    match /securityEvents/{eventId} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------
    // Phase 12: publish jobs. Clients may READ their own jobs (scoped by
    // `uid`). All writes are Admin SDK only — the dispatcher Callable
    // creates the doc, workers update per-platform status, and the DLQ
    // replay callable flips status back to queued.
    // -------------------------------------------------------------------
    match /publish_jobs/{jobId} {
      allow read: if request.auth != null
                    && request.auth.uid == resource.data.uid;
      allow write: if false;
    }

    // -------------------------------------------------------------------
    // Phase 12: DLQ mirror. Ops-only; never exposed to clients.
    // -------------------------------------------------------------------
    match /publish_dlq/{jobId}/{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------
    // Phase 12: server-side telemetry mirror. Cloud Functions workers
    // write to this collection; analytics pipeline reads via server SDK.
    // Never exposed to clients.
    // -------------------------------------------------------------------
    match /telemetry_events/{eventId} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------
    // Phase 13: per-user analytics insight snapshots + rollups.
    // Written by the nightly Cloud Function sync (Admin SDK). Users can
    // read their own but never write — we rely on the sync job as the
    // single source of truth.
    // -------------------------------------------------------------------
    match /users/{uid}/insights/{rest=**} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;  // Cloud Functions only
    }

    // Phase 13: per-user generated insight cards (LLM-free heuristics).
    match /users/{uid}/generatedInsights/{date} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Phase 13: per-user weekly digest docs.
    match /users/{uid}/weeklyDigest/{weekLabel} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // Phase 13: global industry benchmarks (read-only for any auth user).
    // Populated by `seedBenchmarks` CF and refreshed quarterly.
    match /benchmarks/{category}/{metric}/{doc=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Phase 13: global trend signals (read-only for any auth user).
    match /trendSignals/{date} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Phase 13: rate-limit buckets for nightly sync. Admin-only.
    match /_rateLimit/{rest=**} {
      allow read, write: if false;
    }

    // Default deny for any path not matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
