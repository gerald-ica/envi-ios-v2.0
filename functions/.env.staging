# .env.staging — runtime environment for the staging Firebase project.
#
# Firebase Cloud Functions 2nd gen honours a `.env.<projectId>` file at
# deploy time (via firebase-functions runtime config v2). This file is
# committed because it contains NO secrets — only a non-sensitive switch
# that toggles the broker between provider sandbox apps and prod apps.
# Actual credentials live in Secret Manager; see functions/src/lib/secrets.ts.

ENVI_CONNECTOR_ENV=sandbox
FUNCTION_REGION=us-central1
